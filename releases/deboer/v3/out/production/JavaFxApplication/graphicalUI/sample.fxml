      <Rectangle id="centerleft" fx:id="centerLeft" arcHeight="5.0" arcWidth="5.0" fill="WHITE" height="100.0" layoutX="20.0" layoutY="170.0" onMouseClicked="#tappedCenterLeft" stroke="BLACK" strokeType="INSIDE" strokeWidth="2.0" width="100.0" />
      <Rectangle id="centercenter" fx:id="centerCenter" arcHeight="5.0" arcWidth="5.0" fill="WHITE" height="100.0" layoutX="120.0" layoutY="170.0" onMouseClicked="#tappedCenterCenter" stroke="BLACK" strokeType="INSIDE" strokeWidth="2.0" width="100.0" />
