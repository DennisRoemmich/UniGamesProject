      <Rectangle id="topleft" fx:id="topLeft" arcHeight="5.0" arcWidth="5.0" fill="WHITE" height="100.0" layoutX="20.0" layoutY="70.0" onMouseClicked="#tappedTopLeft" stroke="BLACK" strokeType="INSIDE" strokeWidth="2.0" width="100.0" />
      <Rectangle id="topcenter" fx:id="topCenter" arcHeight="5.0" arcWidth="5.0" fill="WHITE" height="100.0" layoutX="120.0" layoutY="70.0" onMouseClicked="#tappedTopCenter" stroke="BLACK" strokeType="INSIDE" strokeWidth="2.0" width="100.0" />
