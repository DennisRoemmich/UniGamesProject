            <Font name="Helvetica" size="13.0" />
         </font></Label>
      <Rectangle id="bottomleft" fx:id="bottomLeft" arcHeight="5.0" arcWidth="5.0" fill="WHITE" height="100.0" layoutX="20.0" layoutY="270.0" onMouseClicked="#tappedBottomLeft" stroke="BLACK" strokeType="INSIDE" strokeWidth="2.0" width="100.0" />
      <Rectangle id="bottomcenter" fx:id="bottomCenter" arcHeight="5.0" arcWidth="5.0" fill="WHITE" height="100.0" layoutX="120.0" layoutY="270.0" onMouseClicked="#tappedBottomCenter" stroke="BLACK" strokeType="INSIDE" strokeWidth="2.0" width="100.0" />
